# Copy to .env next to docker-compose.yml (optional; defaults work for local dev)

NG_HTTP_PORT=8080
NG_DOMAIN=localhost
NG_SITE_TITLE=NativeGallery
NG_ADMIN_EMAIL=admin@localhost
NG_TIMEZONE=Europe/Moscow
NG_DEBUG=false

NG_DB_NAME=ngallery
NG_DB_USER=ngallery
NG_DB_PASS=ngallery_secret
NG_DB_ROOT_PASS=root_secret

NG_AUTO_MIGRATE=1