        },
        {
            "name": "Timezone",
            "description": "Часовой пояс (Europe/Moscow и т.д.).",
            "env_variable": "NG_TIMEZONE",
            "default_value": "Europe/Moscow",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Auto migrate",
            "description": "Импортировать SQL-миграции при старте (1/0).",
            "env_variable": "NG_AUTO_MIGRATE",
            "default_value": "1",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|in:0,1",
            "field_type": "text"
        },
        {
            "name": "Git repository",
            "description": "URL репозитория (только при установке).",
            "env_variable": "NG_REPO",
            "default_value": "https://github.com/Lanmikeman/nativegallery.git",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Git branch",
            "description": "Ветка при установке (main, release-1.7).",
            "env_variable": "NG_BRANCH",
            "default_value": "main",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        }
    ]
}